<?xml version="1.0" encoding="UTF-8"?>
<wsdl:definitions
        xmlns:wsdl="http://schemas.xmlsoap.org/wsdl/"
        xmlns:soap="http://schemas.xmlsoap.org/wsdl/soap/"
        xmlns:tns="http://ws.esb.nexgen.com/schema/creditrisk/v1"
        xmlns:xsd="http://www.w3.org/2001/XMLSchema"
        name="CreditRiskService"
        targetNamespace="http://ws.esb.nexgen.com/schema/creditrisk/v1">

    <!-- ==================== Types ==================== -->
    <wsdl:types>
        <xsd:schema targetNamespace="http://ws.esb.nexgen.com/schema/creditrisk/v1"
                    elementFormDefault="qualified"
                    attributeFormDefault="unqualified">

            <!-- RequestHeader -->
            <xsd:complexType name="RequestHeader">
                <xsd:sequence>
                    <xsd:element name="transactionId" type="xsd:string" minOccurs="1"/>
                    <xsd:element name="timestamp" type="xsd:string" minOccurs="1"/>
                    <xsd:element name="sourceSystem" type="xsd:string" minOccurs="0"/>
                    <xsd:element name="userId" type="xsd:string" minOccurs="0"/>
                </xsd:sequence>
            </xsd:complexType>

            <!-- ResponseHeader -->
            <xsd:complexType name="ResponseHeader">
                <xsd:sequence>
                    <xsd:element name="transactionId" type="xsd:string" minOccurs="0"/>
                    <xsd:element name="timestamp" type="xsd:string" minOccurs="0"/>
                    <xsd:element name="statusCode" type="xsd:string" minOccurs="0"/>
                    <xsd:element name="statusMessage" type="xsd:string" minOccurs="0"/>
                </xsd:sequence>
            </xsd:complexType>

            <!-- CreditScoreDetail -->
            <xsd:complexType name="CreditScoreDetail">
                <xsd:sequence>
                    <xsd:element name="bureauScore" type="xsd:int" minOccurs="0"/>
                    <xsd:element name="bureauScoreRange" type="xsd:string" minOccurs="0"/>
                    <xsd:element name="delinquencyCount" type="xsd:int" minOccurs="0"/>
                    <xsd:element name="inquiryCount" type="xsd:int" minOccurs="0"/>
                    <xsd:element name="openAccountCount" type="xsd:int" minOccurs="0"/>
                    <xsd:element name="totalCreditLimit" type="xsd:decimal" minOccurs="0"/>
                    <xsd:element name="totalBalance" type="xsd:decimal" minOccurs="0"/>
                    <xsd:element name="utilizationRate" type="xsd:decimal" minOccurs="0"/>
                </xsd:sequence>
            </xsd:complexType>

            <!-- IncomeVerificationDetail -->
            <xsd:complexType name="IncomeVerificationDetail">
                <xsd:sequence>
                    <xsd:element name="verificationStatus" type="xsd:string" minOccurs="0"/>
                    <xsd:element name="reportedIncome" type="xsd:decimal" minOccurs="0"/>
                    <xsd:element name="verifiedIncome" type="xsd:decimal" minOccurs="0"/>
                    <xsd:element name="incomeSource" type="xsd:string" minOccurs="0"/>
                    <xsd:element name="debtToIncomeRatio" type="xsd:decimal" minOccurs="0"/>
                </xsd:sequence>
            </xsd:complexType>

            <!-- EmploymentRiskDetail -->
            <xsd:complexType name="EmploymentRiskDetail">
                <xsd:sequence>
                    <xsd:element name="employmentType" type="xsd:string" minOccurs="0"/>
                    <xsd:element name="yearsEmployed" type="xsd:int" minOccurs="0"/>
                    <xsd:element name="industryCategory" type="xsd:string" minOccurs="0"/>
                    <xsd:element name="riskLevel" type="xsd:string" minOccurs="0"/>
                </xsd:sequence>
            </xsd:complexType>

            <!-- DebtServiceDetail -->
            <xsd:complexType name="DebtServiceDetail">
                <xsd:sequence>
                    <xsd:element name="totalMonthlyDebt" type="xsd:decimal" minOccurs="0"/>
                    <xsd:element name="totalMonthlyIncome" type="xsd:decimal" minOccurs="0"/>
                    <xsd:element name="debtServiceRatio" type="xsd:decimal" minOccurs="0"/>
                    <xsd:element name="totalDebtServiceRatio" type="xsd:decimal" minOccurs="0"/>
                    <xsd:element name="affordabilityRating" type="xsd:string" minOccurs="0"/>
                </xsd:sequence>
            </xsd:complexType>

            <!-- CreditRiskReqType -->
            <xsd:complexType name="CreditRiskReqType">
                <xsd:sequence>
                    <xsd:element name="requestHeader" type="tns:RequestHeader" minOccurs="1"/>
                    <xsd:element name="applicantId" type="xsd:string" minOccurs="1"/>
                    <xsd:element name="firstName" type="xsd:string" minOccurs="1"/>
                    <xsd:element name="lastName" type="xsd:string" minOccurs="1"/>
                    <xsd:element name="dateOfBirth" type="xsd:string" minOccurs="1"/>
                    <xsd:element name="socialInsuranceNumber" type="xsd:string" minOccurs="1"/>
                    <xsd:element name="employmentStatus" type="xsd:string" minOccurs="0"/>
                    <xsd:element name="annualIncome" type="xsd:decimal" minOccurs="0"/>
                    <xsd:element name="province" type="xsd:string" minOccurs="0"/>
                    <xsd:element name="postalCode" type="xsd:string" minOccurs="0"/>
                    <xsd:element name="requestChannel" type="xsd:string" minOccurs="0"/>
                    <xsd:element name="productType" type="xsd:string" minOccurs="0"/>
                    <xsd:element name="requestedAmount" type="xsd:decimal" minOccurs="0"/>
                </xsd:sequence>
            </xsd:complexType>

            <!-- CreditRiskResType -->
            <xsd:complexType name="CreditRiskResType">
                <xsd:sequence>
                    <xsd:element name="responseHeader" type="tns:ResponseHeader" minOccurs="1"/>
                    <xsd:element name="applicantId" type="xsd:string" minOccurs="0"/>
                    <xsd:element name="riskCategory" type="xsd:string" minOccurs="0"/>
                    <xsd:element name="overallScore" type="xsd:int" minOccurs="0"/>
                    <xsd:element name="creditScoreDetail" type="tns:CreditScoreDetail" minOccurs="0"/>
                    <xsd:element name="incomeVerification" type="tns:IncomeVerificationDetail" minOccurs="0"/>
                    <xsd:element name="employmentRisk" type="tns:EmploymentRiskDetail" minOccurs="0"/>
                    <xsd:element name="debtService" type="tns:DebtServiceDetail" minOccurs="0"/>
                    <xsd:element name="riskFactors" minOccurs="0">
                        <xsd:complexType>
                            <xsd:sequence>
                                <xsd:element name="factor" type="xsd:string" minOccurs="0" maxOccurs="unbounded"/>
                            </xsd:sequence>
                        </xsd:complexType>
                    </xsd:element>
                    <xsd:element name="recommendation" type="xsd:string" minOccurs="0"/>
                    <xsd:element name="accuracyCode" type="xsd:string" minOccurs="0"/>
                    <xsd:element name="scoringModelVersion" type="xsd:string" minOccurs="0"/>
                </xsd:sequence>
            </xsd:complexType>

            <!-- DetailException -->
            <xsd:complexType name="DetailException">
                <xsd:sequence>
                    <xsd:element name="errorCode" type="xsd:string" minOccurs="0"/>
                    <xsd:element name="errorMessage" type="xsd:string" minOccurs="0"/>
                    <xsd:element name="correlationId" type="xsd:string" minOccurs="0"/>
                </xsd:sequence>
            </xsd:complexType>

            <!-- Root elements -->
            <xsd:element name="CreditRiskRequest" type="tns:CreditRiskReqType"/>
            <xsd:element name="CreditRiskResponse" type="tns:CreditRiskResType"/>
            <xsd:element name="CreditRiskServiceException" type="tns:DetailException"/>

            <!-- Wrapper elements for document/literal style -->
            <xsd:element name="assessCreditRisk">
                <xsd:complexType>
                    <xsd:sequence>
                        <xsd:element name="CreditRiskRequest" type="tns:CreditRiskReqType"/>
                    </xsd:sequence>
                </xsd:complexType>
            </xsd:element>

            <xsd:element name="assessCreditRiskResponse">
                <xsd:complexType>
                    <xsd:sequence>
                        <xsd:element name="CreditRiskResponse" type="tns:CreditRiskResType"/>
                    </xsd:sequence>
                </xsd:complexType>
            </xsd:element>

        </xsd:schema>
    </wsdl:types>

    <!-- ==================== Messages ==================== -->
    <wsdl:message name="assessCreditRiskRequest">
        <wsdl:part name="parameters" element="tns:assessCreditRisk"/>
    </wsdl:message>

    <wsdl:message name="assessCreditRiskResponse">
        <wsdl:part name="parameters" element="tns:assessCreditRiskResponse"/>
    </wsdl:message>

    <wsdl:message name="CreditRiskServiceException">
        <wsdl:part name="fault" element="tns:CreditRiskServiceException"/>
    </wsdl:message>

    <!-- ==================== Port Type ==================== -->
    <wsdl:portType name="CreditRiskSoapSvc">
        <wsdl:operation name="assessCreditRisk">
            <wsdl:input message="tns:assessCreditRiskRequest"/>
            <wsdl:output message="tns:assessCreditRiskResponse"/>
            <wsdl:fault name="CreditRiskServiceException" message="tns:CreditRiskServiceException"/>
        </wsdl:operation>
    </wsdl:portType>

    <!-- ==================== Binding ==================== -->
    <wsdl:binding name="CreditRiskSoapSvcSoapBinding" type="tns:CreditRiskSoapSvc">
        <soap:binding style="document" transport="http://schemas.xmlsoap.org/soap/http"/>
        <wsdl:operation name="assessCreditRisk">
            <soap:operation soapAction="assessCreditRisk"/>
            <wsdl:input>
                <soap:body use="literal"/>
            </wsdl:input>
            <wsdl:output>
                <soap:body use="literal"/>
            </wsdl:output>
            <wsdl:fault name="CreditRiskServiceException">
                <soap:fault name="CreditRiskServiceException" use="literal"/>
            </wsdl:fault>
        </wsdl:operation>
    </wsdl:binding>

    <!-- ==================== Service ==================== -->
    <wsdl:service name="CreditRiskService">
        <wsdl:port name="CreditRiskSoapSvcPort" binding="tns:CreditRiskSoapSvcSoapBinding">
            <soap:address location="http://localhost:8080/nexgen/ws/soap/creditrisk"/>
        </wsdl:port>
    </wsdl:service>

</wsdl:definitions>
