# env.conf.template — NexGen Credit Risk Gateway environment configuration
# Copy to /opt/nexgen-creditrisk/env.conf and fill in all values before starting
# the nexgen-creditrisk systemd service.
# Loaded by systemd EnvironmentFile — Spring Boot reads these via ${VAR} syntax.

# MongoDB connection (Atlas M0 Free Tier)
MONGO_URI=mongodb+srv://nexgen_app:<password>@<cluster>.mongodb.net/nexgen_creditrisk?retryWrites=true&w=majority
MONGO_DB=nexgen_creditrisk
MONGO_COLLECTION=transactions

# External credit bureau integration
BUREAU_ENDPOINT_URL=https://bureau.nexgen.com/services/bureau/creditcheck
BUREAU_STUB_ENABLED=true
